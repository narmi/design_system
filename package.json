{
  "name": "@narmi/design_system",
  "version": "6.17.0",
  "description": "⚡ A consistent look-and-feel and extensible interface for Narmi experiences 🔥",
  "main": "dist/index.js",
  "style": "dist/style.css",
  "files": [
    "dist/*"
  ],
  "types": "dist/types/index.d.ts",
  "engineStrict": true,
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "husky install",
    "build:icon-names": "node ./scripts/buildIconNames.mjs",
    "build:types": "node ./scripts/buildTypes.mjs",
    "build:jsdoc": "node ./scripts/jsDoc.mjs",
    "build:classdoc": "node ./scripts/classManifest.mjs",
    "build:tokens": "style-dictionary build --config=./tokens/config.js",
    "build:css": "sass src/index.scss dist/style.css --style=compressed --source-map",
    "build:components": "vite build && node ./scripts/copyAssets.mjs",
    "build": "npm run build:icon-names && npm run build:tokens && npx tsc && npm run build:css && npm run build:jsdoc && npm run build:components && npm run build:classdoc",
    "build:clean": "rm -rf dist/ && npm run build",
    "prepublish": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"./src/**\" \"./scripts/**\" \"./tokens/**\" --no-error-on-unmatched-pattern",
    "release": "semantic-release",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --stats-json",
    "chromatic": "npx chromatic --project-token $CHROMATIC_PROJECT_TOKEN --exit-zero-on-changes",
    "stats:components": "node ./scripts/component-adoption.mjs",
    "stats:classes": "node ./scripts/class-adoption.mjs",
    "dev": "npm run storybook"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@babel/cli": "^7.1.0",
    "@babel/core": "^7.13.14",
    "@babel/eslint-parser": "^7.17.0",
    "@babel/plugin-proposal-class-properties": "^7.13.0",
    "@babel/preset-env": "^7.15.6",
    "@babel/preset-react": "^7.14.5",
    "@babel/preset-typescript": "^7.23.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@figma/code-connect": "^1.3.10",
    "@mdx-js/mdx": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@storybook/addon-a11y": "^10.4.5",
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/addon-links": "^10.4.5",
    "@storybook/react-vite": "^10.4.5",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.31",
    "@types/react-dom": "^18.2.14",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "chromatic": "^6",
    "cli-table": "^0.3.11",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "core-js": "^3.15.2",
    "css": "^3.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-compat": "^6.0.1",
    "eslint-plugin-json": "^3.1.0",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-react": "^7.29.4",
    "eslint-plugin-storybook": "^10.4.5",
    "husky": "^8.0.3",
    "jsdoc-to-markdown": "^9.1.3",
    "jsdom": "^26.1.0",
    "polished": "^4.1.1",
    "prettier": "^3.2.5",
    "pretty-quick": "^4",
    "prop-types": "^15.7.2",
    "react": "^18.3.1",
    "react-docgen-typescript-plugin": "^1.0.5",
    "react-dom": "^18.3.1",
    "sass": "^1.45.0",
    "semantic-release": "^25.0.3",
    "storybook": "^10.4.5",
    "style-dictionary": "^3.9.2",
    "tinycolor2": "^1.4.2",
    "typescript": "^5.2.2",
    "use-clipboard-copy": "^0.2.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  },
  "author": "@narmi",
  "license": "SEE LICENSE IN LICSENSE.md, VENDOR_LICENSE.md",
  "dependencies": {
    "@maskito/core": "^5.1.0",
    "@maskito/kit": "^5.1.0",
    "@maskito/react": "^5.1.0",
    "classcat": "^5.0.3",
    "dompurify": "^3.4.1",
    "downshift": "^9",
    "flatpickr": "^4.6.12",
    "marked": "^15.0.12",
    "react-aria-components": "^1.0.0",
    "react-focus-lock": "^2.9.4",
    "react-transition-group": "^4.4.5",
    "usehooks-ts": "^3.1.1"
  },
  "overrides": {
    "tar": "7.5.10",
    "handlebars": "^4.7.9",
    "lodash": "^4.18.0",
    "undici": ">=6.27.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narmi/design_system.git"
  },
  "bugs": {
    "url": "https://github.com/narmi/design_system/issues"
  },
  "homepage": "https://github.com/narmi/design_system#readme"
}
