{
  "compilerOptions": {
    "alwaysStrict": false,
    "declaration": true,
    "declarationMap": true,
    "importHelpers": true,
    "inlineSources": true,
    "isolatedModules": true,
    "lib": ["ES2022", "dom"],
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "sourceMap": true,
    "target": "ES6",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "emitDeclarationOnly": true,
    "outDir": "./dist/types",
    "resolveJsonModule": true
  },
  "files": ["src/index.ts", "src/json.d.ts"]
}
